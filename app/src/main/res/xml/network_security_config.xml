<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!-- 
       Разрешаем HTTP (cleartext) трафик для локальной сети, 
       чтобы беспрепятственно общаться с Hermes API Server через Tailscale
    -->
    <base-config cleartextTrafficPermitted="true">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>
</network-security-config>
