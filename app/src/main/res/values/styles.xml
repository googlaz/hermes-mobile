<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- 
       Мы используем системную тему Android Material (NoActionBar), которая встроена в ОС Android нативно.
       Это избавляет нас от тяжелых XML зависимостей (appcompat / material components view),
       так как весь наш интерфейс построен полностью на Jetpack Compose! (НФТ-3)
    -->
    <style name="Theme.Hermes" parent="android:Theme.Material.NoActionBar">
         <item name="android:statusBarColor">#121212</item>
         <item name="android:windowLightStatusBar">false</item>
    </style>
</resources>
